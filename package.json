    "lint-staged": "^13.2.2",
    "prettier": "^3.2.5",
    "ts-jest": "^29.1.2",
    "typescript": "^5.4.4",
    "vite": "^7.3.1",
    "vite-plugin-checker": "^0.10.3",
    "wrangler": "^4.72.0"
