{
  "extends": "./tsconfig.json",
  "compilerOptions": {
    "composite": true,
    "target": "es2021",
    "module": "es2022",
    "moduleResolution": "bundler",
    "tsBuildInfoFile": "./node_modules/.tmp/tsconfig.tests.tsbuildinfo",
    "lib": ["ES2021"],
    "types": ["vite/client"],
    "isolatedModules": true,
    "sourceMap": true
  },
  "include": ["./vite-env.d.ts", "./worker-configuration.d.ts", "./__tests__/**/*", "./src/**/*", "vitest.config.ts"]
}
